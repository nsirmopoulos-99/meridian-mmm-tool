        "\n",
        "if all_dates:\n",
        "    min_date = min(all_dates).strftime('%Y-%m-%d')\n",
        "    max_date = max(all_dates).strftime('%Y-%m-%d')\n",
        "    print(f'\\n📊 Βρέθηκαν δεδομένα από: {min_date} έως {max_date}')\n",
        "    print(f'   (Πάτα Enter για να χρησιμοποιήσεις αυτές τις ημερομηνίες)')\n",
        "else:\n",
