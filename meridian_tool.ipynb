      "source": [
        "# CELL 2 — Ανέβασε τα αρχεία σου\n",
        "from google.colab import files\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "print('📁 Ανέβασε τα αρχεία σου (CSV ή Excel).')\n",
        "print('   Μπορείς να ανεβάσεις 1 ή περισσότερα αρχεία.')\n",
        "uploaded = files.upload()\n",
        "\n",
        "all_sheets = []\n",
        "\n",
        "def find_date_column(df):\n",
        "    \"\"\"Βρίσκει αυτόματα τη date column.\"\"\"\n",
        "    for col in df.columns:\n",
        "        if df[col].dtype == 'datetime64[ns]':\n",
        "            return col\n",
        "        if df[col].dtype == object:\n",
        "            try:\n",
        "                parsed = pd.to_datetime(df[col].dropna().head(5), errors='coerce')\n",
        "                if parsed.notna().sum() >= 3:\n",
        "                    return col\n",
        "            except:\n",
        "                pass\n",
        "        col_lower = str(col).lower()\n",
        "        if any(x in col_lower for x in ['date', 'day', 'week', 'period', 'ημερ', 'περιοδ']):\n",
        "            return col\n",
        "    return None\n",
        "\n",
        "def clean_dataframe(df, filename, sheet_name):\n",
        "    \"\"\"Καθαρίζει και τυποποιεί ένα dataframe.\"\"\"\n",
        "    # Αφαίρεσε κενές γραμμές/columns\n",
        "    df = df.dropna(how='all').dropna(axis=1, how='all')\n",
        "    \n",
        "    # Αν η πρώτη γραμμή μοιάζει με header, χρησιμοποίησέ την\n",
        "    if df.iloc[0].apply(lambda x: isinstance(x, str)).sum() > len(df.columns) * 0.5:\n",
        "        df.columns = df.iloc[0]\n",
        "        df = df.iloc[1:].reset_index(drop=True)\n",
        "    \n",
        "    # Βρες date column\n",
        "    date_col = find_date_column(df)\n",
        "    \n",
        "    return df, date_col\n",
        "\n",
        "for filename in uploaded.keys():\n",
        "    print(f'\\n📂 Διαβάζω: {filename}')\n",
        "    try:\n",
        "        if filename.endswith('.csv'):\n",
        "            df = pd.read_csv(filename, parse_dates=True)\n",
        "            df, date_col = clean_dataframe(df, filename, 'main')\n",
        "            all_sheets.append({\n",
        "                'filename': filename,\n",
        "                'sheet': 'main',\n",
        "                'df': df,\n",
        "                'date_col': date_col\n",
        "            })\n",
        "            print(f'   ✅ {len(df)} γραμμές | Date column: {date_col}')\n",
        "        elif filename.endswith(('.xlsx', '.xls')):\n",
        "            xl = pd.ExcelFile(filename)\n",
        "            for sheet in xl.sheet_names:\n",
        "                try:\n",
        "                    df = pd.read_excel(filename, sheet_name=sheet)\n",
        "                    df, date_col = clean_dataframe(df, filename, sheet)\n",
        "                    if len(df) < 3 or date_col is None:\n",
        "                        print(f'   ⏭  Sheet \"{sheet}\": παραλείπεται (δεν βρέθηκε date column)')\n",
        "                        continue\n",
        "                    all_sheets.append({\n",
        "                        'filename': filename,\n",
        "                        'sheet': sheet,\n",
        "                        'df': df,\n",
        "                        'date_col': date_col\n",
        "                    })\n",
        "                    print(f'   ✅ Sheet \"{sheet}\": {len(df)} γραμμές | Date column: {date_col}')\n",
        "                except Exception as e:\n",
        "                    print(f'   ⚠️  Sheet \"{sheet}\": {e}')\n",
        "    except Exception as e:\n",
        "        print(f'   ❌ Σφάλμα: {e}')\n",
        "\n",
        "print(f'\\n✅ Φορτώθηκαν {len(all_sheets)} πίνακες με έγκυρα δεδομένα.')\n",
        "print('➡️  Τρέξε το επόμενο cell.')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# CELL 3 — Έξυπνη αναγνώριση columns\n",
        "print('=' * 60)\n",
        "print('🤖 ΑΥΤΟΜΑΤΗ ΑΝΑΓΝΩΡΙΣΗ COLUMNS')\n",
        "print('=' * 60)\n",
        "\n",
        "def guess_column_type(col_name, sample_values, dtype):\n",
        "    \"\"\"Μαντεύει τον τύπο ενός column.\"\"\"\n",
        "    col_lower = str(col_name).lower()\n",
        "    \n",
        "    # Date\n",
        "    if any(x in col_lower for x in ['date', 'day', 'week', 'period', 'ημερ']):\n",
        "        return 'date', '📅 DATE'\n",
        "    \n",
        "    # Skip\n",
        "    if any(x in col_lower for x in ['unnamed', 'δ1', 'δ2', 'δ3', 'δ4', '%', 'analytics', \n",
        "                                      'transactions', 'traffic', 'vendallion', 'net/', 'aop']):\n",
        "        return 'skip', '⏭  ΠΑΡΑΛΕΙΨΕ'\n",
        "    \n",
        "    # KPI / Revenue\n",
        "    if any(x in col_lower for x in ['revenue', 'kpi', 'sales', 'conversion', 'net revenue',\n",
        "                                      'έσοδα', 'πωλήσεις']):\n",
        "        return 'kpi', '💰 KPI/REVENUE'\n",
        "    \n",
        "    # Media Spend\n",
        "    if any(x in col_lower for x in ['euro', 'spend', 'cost', 'budget', 'κόστος', '€', \n",
        "                                      'eur', '_euro', 'skroutz', 'bestprice', 'best price',\n",
        "                                      'kelkoo', 'criteo']):\n",
        "        return 'media_spend', '📢 MEDIA SPEND'\n",
        "    \n",
        "    # Impressions\n",
        "    if any(x in col_lower for x in ['impression', 'impr', 'reach', 'views', 'clicks',\n",
        "                                      'sessions', 'session']):\n",
        "        return 'media_impressions', '👁  IMPRESSIONS'\n",
        "    \n",
        "    # Control\n",
        "    if any(x in col_lower for x in ['season', 'holiday', 'promo', 'index', 'trend']):\n",
        "        return 'control', '🎛  CONTROL'\n",
        "    \n",
        "    return 'skip', '⏭  ΠΑΡΑΛΕΙΨΕ'\n",
        "\n",
        "# Μάζεψε όλα τα columns\n",
        "all_columns_info = []\n",
        "for sheet_info in all_sheets:\n",
        "    df = sheet_info['df']\n",
        "    date_col = sheet_info['date_col']\n",
        "    for col in df.columns:\n",
        "        sample = df[col].dropna().head(3).tolist()\n",
        "        dtype = str(df[col].dtype)\n",
        "        if col == date_col:\n",
        "            guessed_type, guessed_label = 'date', '📅 DATE'\n",
        "        else:\n",
        "            guessed_type, guessed_label = guess_column_type(col, sample, dtype)\n",
        "        all_columns_info.append({\n",
        "            'filename': sheet_info['filename'],\n",
        "            'sheet': sheet_info['sheet'],\n",
        "            'column': col,\n",
        "            'dtype': dtype,\n",
        "            'sample': sample,\n",
        "            'guessed_type': guessed_type,\n",
        "            'guessed_label': guessed_label\n",
        "        })\n",
        "\n",
        "# Εμφάνιση περίληψης\n",
        "from collections import Counter\n",
        "type_counts = Counter(c['guessed_type'] for c in all_columns_info)\n",
        "print(f'\\n📊 Αναγνωρίστηκαν {len(all_columns_info)} columns:')\n",
        "for t, count in type_counts.items():\n",
        "    print(f'   {t}: {count}')\n",
        "\n",
        "print('\\n➡️  Τρέξε το επόμενο cell για επιβεβαίωση.')"
      ],
      "execution_count": null,
      "outputs": []
    },
