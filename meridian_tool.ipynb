        "\n",
        "    channel_name = None\n",
        "    if col_type in ['media_spend', 'media_impressions']:\n",
        "        # Πρότεινε αυτόματα όνομα channel από το column name\n",
        "        col_name = str(info['column'])\n",
        "        suggested = col_name.replace('_Euro', '').replace('_Impressions', '').replace('Client_media_Performance ', '').replace('Client_media_Awa ', 'Awareness ').strip()\n",
        "        print(f'   Όνομα channel (Enter για \"{suggested}\"): ', end='')\n",
        "        channel_input = input().strip()\n",
        "        channel_name = channel_input if channel_input else suggested\n",
        "\n",
        "    confirmed_mapping.append({\n",
        "        'filename': info['filename'],\n",
        "        'sheet': info['sheet'],\n",
        "        'column': info['column'],\n",
        "        'type': col_type,\n",
        "        'channel_name': channel_name\n",
        "    })\n",
        "    print(f'   ✅ {type_labels[col_type]}' + (f' → {channel_name}' if channel_name else ''))\n",
        "\n",
        "print('\\n' + '=' * 60)\n",
        "print('📋 ΠΕΡΙΛΗΨΗ ΕΠΙΒΕΒΑΙΩΜΕΝΩΝ COLUMNS:')\n",
