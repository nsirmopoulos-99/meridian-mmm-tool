        "# CELL 5 — Date range\n",
        "print('=' * 60)\n",
        "print('📅 ΟΡΙΣΜΟΣ DATE RANGE')\n",
        "print('=' * 60)\n",
        "\n",
        "# Βρες αυτόματα το range από τα δεδομένα\n",
        "all_dates = []\n",
        "for sheet_info in all_sheets:\n",
        "    df = sheet_info['df']\n",
        "    date_col = sheet_info['date_col']\n",
