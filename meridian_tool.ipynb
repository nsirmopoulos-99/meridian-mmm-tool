        "    else:\n",
        "        print('   Τι είναι αυτό;')\n",
        "        print('   1=DATE 2=KPI 3=MEDIA SPEND 4=IMPRESSIONS 5=CONTROL 6=ΠΑΡΑΛΕΙΨΕ')\n",
        "        new_choice = input('   Επίλεξε [1-6]: ').strip()\n",
        "        col_type = type_map.get(new_choice, 'skip')\n",
        "\n",
        "    if col_type == 'skip':\n",
