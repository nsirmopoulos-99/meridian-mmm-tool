    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# CELL 6 — Προετοιμασία & συνένωση δεδομένων\n",
        "print('⚙️  Προετοιμασία δεδομένων...')\n",
        "\n",
        "# Χτίσε lookup για sheet dataframes\n",
        "sheet_lookup = {(s['filename'], s['sheet']): s for s in all_sheets}\n",
        "\n",
        "def get_series(mapping_info):\n",
        "    key = (mapping_info['filename'], mapping_info['sheet'])\n",
        "    df = sheet_lookup[key]['df']\n",
        "    date_col = sheet_lookup[key]['date_col']\n",
        "    col = mapping_info['column']\n",
        "    series = df[[date_col, col]].copy()\n",
        "    series.columns = ['date', col]\n",
        "    series['date'] = pd.to_datetime(series['date'], errors='coerce')\n",
        "    series[col] = pd.to_numeric(series[col], errors='coerce')\n",
        "    return series.dropna(subset=['date'])\n",
        "\n",
        "# Διαχωρισμός ανά τύπο\n",
        "date_cols = [m for m in confirmed_mapping if m['type'] == 'date']\n",
        "kpi_cols = [m for m in confirmed_mapping if m['type'] == 'kpi']\n",
        "spend_cols = [m for m in confirmed_mapping if m['type'] == 'media_spend']\n",
        "impr_cols = [m for m in confirmed_mapping if m['type'] == 'media_impressions']\n",
        "control_cols_m = [m for m in confirmed_mapping if m['type'] == 'control']\n",
        "\n",
        "# Ξεκίνα με KPI\n",
        "kpi_series_list = []\n",
        "for m in kpi_cols:\n",
        "    s = get_series(m)\n",
        "    s = s.rename(columns={m['column']: 'kpi'})\n",
        "    kpi_series_list.append(s)\n",
        "\n",
        "if kpi_series_list:\n",
        "    kpi_df = pd.concat(kpi_series_list).groupby('date')['kpi'].sum().reset_index()\n",
        "else:\n",
        "    raise ValueError('❌ Δεν βρέθηκε KPI column!')\n",
        "\n",
        "merged = kpi_df.copy()\n",
        "\n",
        "# Πρόσθεσε spend\n",
        "media_spend_map = {}\n",
        "for m in spend_cols:\n",
        "    col_key = f\"{m['channel_name']}_spend\"\n",
        "    s = get_series(m).rename(columns={m['column']: col_key})\n",
        "    merged = merged.merge(s, on='date', how='left')\n",
        "    merged[col_key] = merged[col_key].fillna(0)\n",
        "    media_spend_map[col_key] = m['channel_name']\n",
        "\n",
        "# Πρόσθεσε impressions\n",
        "media_channels = {}\n",
        "for m in impr_cols:\n",
        "    col_key = f\"{m['channel_name']}_impressions\"\n",
        "    s = get_series(m).rename(columns={m['column']: col_key})\n",
        "    merged = merged.merge(s, on='date', how='left')\n",
        "    merged[col_key] = merged[col_key].fillna(0)\n",
        "    media_channels[col_key] = m['channel_name']\n",
        "\n",
        "# Πρόσθεσε controls\n",
        "control_names = []\n",
        "for m in control_cols_m:\n",
        "    col_key = m['column']\n",
        "    s = get_series(m).rename(columns={m['column']: col_key})\n",
        "    merged = merged.merge(s, on='date', how='left')\n",
        "    merged[col_key] = merged[col_key].fillna(0)\n",
        "    control_names.append(col_key)\n",
        "\n",
        "# Φιλτράρισμα date range\n",
        "merged = merged[(merged['date'] >= date_start) & (merged['date'] <= date_end)]\n",
        "merged = merged.sort_values('date').reset_index(drop=True)\n",
        "\n",
        "# Μετατροπή σε εβδομαδιαία δεδομένα αν είναι daily\n",
        "date_diffs = merged['date'].diff().dropna().dt.days\n",
        "avg_diff = date_diffs.median()\n",
        "\n",
        "if avg_diff < 6:\n",
        "    print(f'   📅 Εντοπίστηκαν daily δεδομένα — μετατροπή σε weekly...')\n",
        "    merged['date'] = merged['date'] - pd.to_timedelta(merged['date'].dt.dayofweek, unit='D')\n",
        "    agg_dict = {'kpi': 'sum'}\n",
        "    for col in list(media_spend_map.keys()) + list(media_channels.keys()) + control_names:\n",
        "        agg_dict[col] = 'sum'\n",
        "    merged = merged.groupby('date').agg(agg_dict).reset_index()\n",
        "    print(f'   ✅ Μετατράπηκε σε {len(merged)} εβδομαδιαίες εγγραφές')\n",
        "else:\n",
        "    print(f'   ✅ Δεδομένα ήδη σε εβδομαδιαία μορφή: {len(merged)} εγγραφές')\n",
        "\n",
        "merged.to_csv('/content/prepared_data.csv', index=False)\n",
        "\n",
        "print(f'\\n✅ Δεδομένα έτοιμα!')\n",
        "print(f'   📅 Από: {merged[\"date\"].min().date()} → {merged[\"date\"].max().date()}')\n",
        "print(f'   📊 Εγγραφές: {len(merged)} εβδομάδες')\n",
        "print(f'   💰 KPI μέσος: {merged[\"kpi\"].mean():.0f}')\n",
        "print(f'   📢 Spend channels: {list(media_spend_map.values())}')\n",
        "print('\\n➡️  Τρέξε το επόμενο cell για το Meridian model.')"
