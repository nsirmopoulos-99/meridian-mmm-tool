        "\n",
        "date_start_input = input(f'\\nΑρχή περιόδου [{min_date}]: ').strip()\n",
        "date_end_input = input(f'Τέλος περιόδου [{max_date}]: ').strip()\n",
        "\n",
        "date_start = date_start_input if date_start_input else min_date\n",
        "date_end = date_end_input if date_end_input else max_date\n",
        "\n",
        "print(f'\\n✅ Περίοδος: {date_start} → {date_end}')\n",
